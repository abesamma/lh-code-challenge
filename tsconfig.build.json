        "outDir": "./dist",
        "noEmit": false,
        "declaration": false,
        "declarationMap": false
    },
    "include": [
        "src/**/*.ts"
    ],
    "exclude": [
        "tests/**",
        "scripts/**",
        "playwright.config.ts"
    ]
}